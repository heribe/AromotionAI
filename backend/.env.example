# ========== AromotionAI 后端环境配置示例 ==========
# 用法：复制为 .env 并填入真实值（cp .env.example .env）。
# .env 已被 .gitignore 忽略，不会入库。
#
# 本文件用于【本地开发】，列了全部变量。
# 【docker compose 部署】请用仓库根目录的 .env.example（只含部署需调的变量）。

# ---------- AI 模型（智谱 GLM）----------
# 必填：智谱开放平台 API Key（注册并创建：https://open.bigmodel.cn/）
GLM_API_KEY=
# Coding Plan 套餐专用端点（标准套餐留空，自动走 /api/paas/v4/）
ZHIPUAI_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
# 可选：覆盖默认模型（默认 glm-5.2 文本 / glm-4.6v 视觉）
# GLM_MODEL=glm-5.2
# GLM_VISION_MODEL=glm-4.6v

# ---------- 抖音采集 Cookie ----------
# Cookie 文件目录（相对 backend/，默认 data/cookies）
COOKIE_DIR=./data/cookies
#
# 【重要】抖音 Cookie 放置方式（前端暂无导入功能）：
#   把浏览器导出的抖音 Cookie（JSON 数组格式，如 EditThisCookie 导出）
#   放到：backend/data/cookies/douyin.json
#   采集器会自动读取（DB 无 cookie 时回退此文件）。
#
#   - 路径在 .gitignore 中，不会入库
#   - 部署时用 scp / 挂载卷 / CI 注入 把文件放进容器对应路径
#   - cookie 失效后，替换该文件并重启服务即可
#   - 将来前端做了 Cookie 导入，会写入数据库，DB 命中优先于本文件
#
# 备选：服务起来后通过 HTTP 上传到 DB：
#   curl -X POST http://localhost:8000/api/v1/cookies/upload \
#        -F "platform=douyin" -F "file=@douyin.json"

# ---------- 数据库 / 存储 ----------
# 开发用 SQLite（零配置）；生产建议改 PostgreSQL
DATABASE_URL=sqlite:///./data/db/aromotion.db
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./data/media

# ---------- 其他 ----------
APP_ENV=development
CORS_ORIGINS=http://localhost:5173
