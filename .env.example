# ========== AromotionAI 部署环境配置（docker compose 用）==========
#
# 本文件只放「docker compose 部署时需要你调整」的变量。
# compose 已为其余变量（DATABASE_URL / COOKIE_DIR / STORAGE 等）设置容器内默认值，
# 无需在此重复。
#
# 本地开发（不走 docker）请看 backend/.env.example，那里列了全部变量。
# .env 不要入库（已在 .gitignore）。

# ---------- AI 模型（智谱 GLM）----------
# 必填：智谱开放平台 API Key（注册并创建：https://open.bigmodel.cn/）
GLM_API_KEY=

# Coding Plan 套餐专用端点；标准套餐留空，会自动走 https://open.bigmodel.cn/api/paas/v4/
ZHIPUAI_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4

# 可选：覆盖默认模型（默认 glm-5.2 文本 / glm-4.6v 视觉）
# GLM_MODEL=glm-5.2
# GLM_VISION_MODEL=glm-4.6v

# ---------- 抖音 Cookie（部署必填，否则采集报错）----------
# 抖音 Cookie 文件放到宿主机 ./data/backend/cookies/douyin.json
# （compose 会把它挂载进容器 /app/data/cookies/douyin.json）
# 格式：浏览器导出的 JSON 数组（如 EditThisCookie 导出）
# 详见 DEPLOY.md

# ---------- 可选：跨域 / 域名 ----------
# 生产走 nginx 同源，CORS 一般不生效，留空即可
# 直连后端（如调试）才需要设
# CORS_ORIGINS=https://your-domain.com
