# ========== AromotionAI 部署环境配置 ==========
# 用法：复制为 .env 并填值。docker compose 会自动读取本文件。
# .env 不要入库（已在 .gitignore）。

# ---------- AI 模型（智谱 GLM）----------
# 必填：智谱 API Key
GLM_API_KEY=

# Coding Plan 套餐端点（标准套餐留空；Coding Plan 用这个）
ZHIPUAI_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4

# 可选：覆盖默认模型（默认 glm-5.2 / glm-4.6v）
# GLM_MODEL=glm-5.2
# GLM_VISION_MODEL=glm-4.6v

# 可选：允许直连后端的跨域来源（生产走 nginx 同源，一般留空）
# CORS_ORIGINS=https://your-domain.com
